{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" }
  ],
  "functions": {
    "api/index.py": {
      "memory": 512,
      "maxDuration": 30,
      "excludeFiles": "{models/*.pkl,notebooks/**,data_raw/**,data_processed/**,django_ui/**,app/**,.venv*/**,convert_models.py}"
    }
  }
}
